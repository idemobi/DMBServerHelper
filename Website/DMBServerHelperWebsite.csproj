<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <RootNamespace>DMBServerHelperWebsite</RootNamespace>
        <TargetFramework>net10.0</TargetFramework>
        <Description>Local ASP.NET Core host website for testing DMBServerHelper labs pages independently.</Description>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <EnableDefaultRazorGenerateItems>true</EnableDefaultRazorGenerateItems>
        <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
        <IncludeRazorContentInPack>false</IncludeRazorContentInPack>
        <EmbedRazorGenerateSources>false</EmbedRazorGenerateSources>
        <Configurations>Debug;Release;NuGet</Configurations>
        <Company>idéMobi</Company>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Labs\DMBServerHelperLabs.csproj" />
        <ProjectReference Include="..\Source\DMBServerHelper.csproj" />
        <PackageReference Include="DMBServerWebHelper" Version="0.16.1-preview.1" />
        <PackageReference Include="DMBPageBuilder" Version="0.16.1-preview.1" />
        <PackageReference Include="DMBBootstrapBuilder" Version="0.16.1-preview.1" />
        <PackageReference Include="DMBComponentBuilder" Version="0.16.1-preview.1" />
        <PackageReference Include="DMBEffectBuilder" Version="0.16.1-preview.1" />
    </ItemGroup>

</Project>

                    {
                        @:Cookies
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Definitions hold storage metadata, lifetime, SameSite, Secure, and typed defaults.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-database-check fs-2 text-success d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Sessions
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Session helpers expose typed values while keeping ASP.NET Core session access centralized.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-globe2 fs-2 text-warning d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Domains
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:DomainComposite parses hosts, ports, IPs, localhost, subdomains, and public suffixes.
                    }
                }
            }
        }
    }
}

@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @Html.TitleBuilder().SetTitle("Cookie Definitions", TitleLevel.Two).AsSectionHeading().Render()
    @using (Html.RowBuilder().SetGapY(Gap.G4).Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col6, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.CardBuilder().SetTitle("Theme cookie", TitleLevel.Three).SetIconBootstrap("bi-cookie").Begin())
            {
                @using (Html.TableBuilder().SetSmall().Begin())
                {
                    @using (Html.TableBodyBuilder().Begin())
                    {
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Name 
                }
                            @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @themeCookie.Name } }
                        }
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Group 
                }
                            @using (Html.TableCellBuilder().Begin()) { @themeCookie.Group }
                        }
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Current value 
                }
                            @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @currentThemeValue } }
                        }
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Generated data 
                }
                            @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @encodedCookieData } }
                        }
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col6, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.CardBuilder().SetTitle("Consent cookie", TitleLevel.Three).SetIconBootstrap("bi-shield-check").Begin())
            {
                @using (Html.TableBuilder().SetSmall().Begin())
                {
                    @using (Html.TableBodyBuilder().Begin())
                    {
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Name 
                }
                            @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @consentCookie.Name } }
                        }
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Group 
                }
                            @using (Html.TableCellBuilder().Begin()) { @consentCookie.Group }
                        }
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Current value 
                }
                            @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @consentCookie.GetValue(Context) } }
                        }
                        @using (Html.TableRowBuilder().Begin())
                        {
                            @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:JavaScript 
                }
                            @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @consentOnClick } }
                        }
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).Begin())
        {
            @using (Html.CardBuilder().SetTitle("Cookie code", TitleLevel.Three).SetIconBootstrap("bi-code-square").Begin())
            {
                @(Html.CodeBlock(@"CookieString themeCookie = new CookieString(
    ""Labs Example Theme"",
    ""Theme preference"",
    ""Stores the selected visual theme."",
    CookieDefinitionGroup.Preference,
    ""light"",
    duration: 30,
    secure: true,
    limitSite: Microsoft.AspNetCore.Http.SameSiteMode.Lax);

string cookieData = themeCookie.GenerateCookieDataString(""dark mode; beta:on"");
string currentValue = themeCookie.GetValue(HttpContext);", CodeLanguage.CSharp)
                    .SetTitle("Cookie definition")
                    .SetCopyButton()
                    .SetCompact())
            }
        }
    }
}


@using DMBBootstrapBuilder
@using DMBComponentBuilder
@using DMBEffectBuilder
@using DMBPageBuilder
@using DMBServerHelper
@{
    Layout = "_Layout";

    CookieString themeCookie = new CookieString(
        "Labs Example Theme",
        "Theme preference",
        "Stores the selected visual theme for the labs examples.",
        CookieDefinitionGroup.Preference,
        "light",
        duration: 30,
        secure: true,
        limitSite: Microsoft.AspNetCore.Http.SameSiteMode.Lax);

    CookieBool consentCookie = new CookieBool(
        "Labs Example Consent",
        "Example consent",
        "Stores a sample consent value.",
        CookieDefinitionGroup.Consent,
        false,
        duration: 365,
        secure: true,
        limitSite: Microsoft.AspNetCore.Http.SameSiteMode.Lax);

    SessionString profileSession = new SessionString(
        "Labs Example Profile",
        "Profile",
        "Stores a sample profile label.",
        SessionDefinitionGroup.Preference,
        "Ada Lovelace",
        deletable: true);

    SessionInt visitSession = new SessionInt(
        "Labs Example Visit Count",
        "Visit count",
        "Counts visits to this documentation page within the current session.",
        SessionDefinitionGroup.Navigation,
        0,
        deletable: true);

    profileSession.SetValue(Context, "Ada Lovelace");
    visitSession.IncrementValue(Context);

    string encodedCookieData = themeCookie.GenerateCookieDataString("dark mode; beta:on");
    string consentOnClick = consentCookie.GenerateOnClick(true);
    string currentThemeValue = themeCookie.GetValue(Context);
    string currentProfileValue = profileSession.GetValue(Context);
    int visitCount = visitSession.GetValue(Context);

    var domainExamples = new[]
    {
        "labs.idemobi.com",
        "https://docs.example.co.uk:8443/path",
        "https://127.0.0.1:7174",
        "https://[::1]:7174",
        "localhost:7174"
    }
        .Select(input => new
        {
            Input = input,
            Composite = new DomainComposite(input, false, TimeSpan.FromSeconds(1))
        })
        .ToArray();

    string requiredMessage = WebLocalizer.GetDataAnnotation("FormBuilder_Field_Required").Value;
    string sampleMessage = WebLocalizer.GetInternal("LABS_SAMPLE_KEY").Value;
    string missingMessage = WebLocalizer.GetInternal("LABS_MISSING_SAMPLE_KEY").Value;
}

@using (Html.SectionBuilder().SetHeight(150, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Examples - DMBServerHelper", TitleLevel.One).Render()
            @using (Html.PB_P().AsLead().Begin())
            {
                @:Typed cookies, session definitions, localization lookups, and domain composition.
            }
            @using (Html.FlexBlockBuilder().SetJustifyContentCenter().WithGap(Old_Gap.Gap2).Begin())
            {
                @Html.Button(ActionItemFactory.AspRoute("ServerHelper", "Introduction").SetTitle("Introduction").SetIcon(IconStruct.Bootstrap("bi-house")).SetVariant(VariantStyle.Secondary).SetOutlined()).Render()
                @Html.Button(ActionItemFactory.AspRoute("ServerHelper", "Architecture").SetTitle("Architecture").SetIcon(IconStruct.Bootstrap("bi-diagram-3")).SetVariant(VariantStyle.Primary).SetOutlined()).Render()
            }
        }
    }
}

@using (Html.BlockBuilder().AsSectionContentTop().Begin())
{

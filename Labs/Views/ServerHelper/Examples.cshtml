@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @Html.TitleBuilder().SetTitle("Localization Lookup", TitleLevel.Two).AsSectionHeading().Render()
    @using (Html.RowBuilder().SetGapY(Gap.G4).Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.CardBuilder().SetTitle("Registered key", TitleLevel.Three).SetIconBootstrap("bi-translate").Begin())
            {
                @using (Html.PB_P().AsSmallMuted().AddClass("mb-2").Begin()) {
                    @:Package data annotation localizer 
                }
                @using (Html.PB_Span().AsMonospace().AddClass("d-block text-break mb-3").Begin()) {
                    @:FormBuilder_Field_Required 
                }
                @using (Html.BlockBuilder().Begin()) { @requiredMessage }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.CardBuilder().SetTitle("Labs host key", TitleLevel.Three).SetIconBootstrap("bi-file-earmark-text").Begin())
            {
                @using (Html.PB_P().AsSmallMuted().AddClass("mb-2").Begin()) {
                    @:Host internal localizer 
                }
                @using (Html.PB_Span().AsMonospace().AddClass("d-block text-break mb-3").Begin()) {
                    @:LABS_SAMPLE_KEY 
                }
                @using (Html.BlockBuilder().Begin()) { @sampleMessage }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.CardBuilder().SetTitle("Fallback key", TitleLevel.Three).SetIconBootstrap("bi-question-circle").Begin())
            {
                @using (Html.PB_P().AsSmallMuted().AddClass("mb-2").Begin()) {
                    @:Internal localizer fallback 
                }
                @using (Html.PB_Span().AsMonospace().AddClass("d-block text-break mb-3").Begin()) {
                    @:LABS_MISSING_SAMPLE_KEY 
                }
                @using (Html.BlockBuilder().Begin()) { @missingMessage }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).Begin())
        {
            @using (Html.CardBuilder().SetTitle("Localization code", TitleLevel.Three).SetIconBootstrap("bi-code-square").Begin())
            {
                @(Html.CodeBlock(@"var labsLocalizerFactory = new ResourceManagerStringLocalizerFactory(
    Options.Create(new LocalizationOptions()),
    NullLoggerFactory.Instance);

WebLocalizer.InternalLocalizer.InjectResource(
    nameof(LabsInternalLocalization),
    labsLocalizerFactory.Create(typeof(LabsInternalLocalization)));

LocalizedString sample = WebLocalizer.GetInternal(""LABS_SAMPLE_KEY"");
LocalizedString message = WebLocalizer.GetDataAnnotation(""FormBuilder_Field_Required"");
LocalizedString fallback = WebLocalizer.GetInternal(""LABS_MISSING_SAMPLE_KEY"");", CodeLanguage.CSharp)
                    .SetTitle("Localization lookup")
                    .SetCopyButton()
                    .SetCompact())
            }
        }
    }
}

@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @Html.TitleBuilder().SetTitle("DomainComposite", TitleLevel.Two).AsSectionHeading().Render()
    @using (Html.PB_P().AsMuted().Begin())
    {
        @:The online Public Suffix List refresh is disabled here so the examples stay deterministic while rendering the documentation page.
    }

    @using (Html.CardBuilder().SetTitle("Domain parsing matrix", TitleLevel.Three).SetIconBootstrap("bi-globe2").Begin())
    {
        @using (Html.TableBuilder().SetSmall().SetResponsive(TableResponsiveBreakpoint.Always).Begin())
        {
            @using (Html.TableHeaderBuilder().Begin())
            {
                @using (Html.TableRowBuilder().Begin())
                {
                    @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Input 
                }
                    @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Domain 
                }
                    @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Subdomain 
                }
                    @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Port 
                }
                    @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:Localhost 
                }
                    @using (Html.TableCellBuilder(isHeader: true).Begin()) {
                    @:HTTPS website 
                }
                }
            }
            @using (Html.TableBodyBuilder().Begin())
            {
                @foreach (var row in domainExamples)
                {
                    @using (Html.TableRowBuilder().Begin())
                    {
                        @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @row.Input } }
                        @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @row.Composite.Domain } }
                        @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @row.Composite.SubDomain } }
                        @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @row.Composite.Port } }
                        @using (Html.TableCellBuilder().Begin()) { @row.Composite.Localhost }
                        @using (Html.TableCellBuilder().Begin()) { @using (Html.PB_Span().AsMonospace().Begin()) { @row.Composite.HttpsWebsite } }
                    }
                }
            }
        }
    }

    @using (Html.BlockBuilder().AsTopMargin().Begin())
    {
        @using (Html.CardBuilder().SetTitle("Domain code", TitleLevel.Three).SetIconBootstrap("bi-code-square").Begin())
        {
            @(Html.CodeBlock(@"DomainComposite composite = new DomainComposite(
    ""https://docs.example.co.uk:8443/path"",
    publicSuffixListOnlineRefreshEnabled: false,
    publicSuffixListRefreshTimeout: TimeSpan.FromSeconds(1));

string domain = composite.Domain;
string subdomain = composite.SubDomain;
string httpsWebsite = composite.HttpsWebsite;", CodeLanguage.CSharp)
                .SetTitle("Domain parsing")
                .SetCopyButton()
                .SetCompact())
        }
    }
}

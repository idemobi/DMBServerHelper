@using DMBBootstrapBuilder
@using DMBComponentBuilder
@using DMBEffectBuilder
@using DMBPageBuilder
@{
    Layout = "_Layout";
}

@* ── Hero ── *@
@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Introduction — DMBServerHelper", TitleLevel.One).Render()
            @using (Html.PB_P().AsLead().Begin())
            {
                @:Shared server foundations for the DMB stack.
            }
            @using (Html.FlexBlockBuilder().SetJustifyContentCenter().WithGap(Old_Gap.Gap2).Begin())
            {
                @Html.Button(ActionItemFactory.AspRoute("ServerHelper", "GettingStarted").SetTitle("Get Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                @Html.Button(ActionItemFactory.AspRoute("ServerHelper", "Architecture").SetTitle("Architecture").SetIcon(IconStruct.Bootstrap("bi-diagram-3")).SetVariant(VariantStyle.Secondary).SetOutlined()).Render()
            }
        }
    }
}

@* ── 3 highlight cards ── *@
@using (Html.BlockBuilder().AsSectionContentTop().Begin())
{
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-tools fs-2 text-primary d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Configuration
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Shared configuration objects and bootstrap methods keep package setup consistent.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-translate fs-2 text-success d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Localization
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Localizer helpers and resource conventions provide a common translation surface.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-shield-check fs-2 text-warning d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:State Helpers
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Cookie and session definitions describe typed state values without duplicating storage conventions.
                    }
                }
            }
        }
    }
}

@* ── What is + preview ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.RowBuilder().SetGapY(Gap.G5).SetAlignItems(AlignItems.Center).Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col7, ResponsiveBreakpoint.Lg).Begin())
        {
            @Html.TitleBuilder().SetTitle("What is DMBServerHelper?", TitleLevel.Two).AsSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @using (Html.PB_Span().AsBold().Begin())
                {
                    @:DMBServerHelper
                }
                @: contains the server-side utilities that are useful before a request reaches a visual builder. It centralizes configuration patterns, localization helpers, validation adapters, cookie helpers and session helpers used by higher-level packages.
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Intentionally independent from the visual layer
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Relied on by
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:DMBServerWebHelper
                    }
                    @:,
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:DMBPageBuilder
                    }
                    @: and
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:BootstrapBuilder
                    }
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:One call to register shared server services at startup
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col5, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPreviewWrapper().Begin())
                {
                    @(Html.CodeBlock(@"ServerHelperConfiguration.LoadCommonConfig(builder);
ServerHelperConfiguration.Config.CookiePrefix = ""BBT"";", CodeLanguage.CSharp))
                }
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Register shared server services at application startup.
                    }
                }
            }
        }
    }
}

@* ── Three Pillars ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.BlockBuilder().AsTextCenter().Begin())
    {
        @Html.TitleBuilder().SetTitle("Three Pillars of DMBServerHelper", TitleLevel.Two).AsSectionHeading().Render()
        @using (Html.PB_P().AsMuted().Begin())
        {
            @:Each pillar targets a different server-side concern.
        }
    }
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-tools text-primary me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Configuration", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Shared configuration objects and bootstrap methods keep package setup consistent across applications.
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-translate text-success me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Localization", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Localizer helpers and resource conventions provide a common translation surface for server features.
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-shield-check text-warning me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("State Helpers", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Cookie and session definitions describe typed state values without duplicating storage conventions.
                }
            }
        }
    }
}

@* ── Philosophy ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.FlexBlockBuilder().WithGap(Old_Gap.Gap3).SetAlignItemsStretch().Begin())
    {
        @using (Html.BlockBuilder().AsInfoCallout().SetStyle("margin", "0").SetStyle("flex", "2").Begin())
        {
            @using (Html.FlexBlockBuilder().Begin())
            {
                @using (Html.BlockBuilder().AsCalloutIcon().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-lightbulb-fill fs-2 text-info").Begin()) { }
                }
                @using (Html.BlockBuilder().Begin())
                {
                    @Html.TitleBuilder().SetTitle("Role in the stack", TitleLevel.Four).AsAlertHeading().Render()
                    @using (Html.PB_P().AsNoMargin().Begin())
                    {
                        @:DMBServerHelper is intentionally independent from the visual layer. Packages such as
                        @using (Html.PB_Span().AsMonospace().Begin())
                        {
                            @:DMBServerWebHelper
                        }
                        @:,
                        @using (Html.PB_Span().AsMonospace().Begin())
                        {
                            @:DMBPageBuilder
                        }
                        @: and
                        @using (Html.PB_Span().AsMonospace().Begin())
                        {
                            @:BootstrapBuilder
                        }
                        @: can rely on its server conventions without owning them.
                    }
                }
            }
        }
        @using (Html.BlockBuilder().AsSidebarCard().SetStyle("flex", "1").Begin())
        {
            @using (Html.BlockBuilder().AsPaddedBlock().SetStyle("height", "100%").Begin())
            {
                @using (Html.FlexBlockBuilder().SetFlexColumn().SetAlignItemsStart().SetJustifyContentCenter().SetStyle("height", "100%").Begin())
                {
                    @Html.TitleBuilder().SetTitle("Next Step", TitleLevel.Five).Render()
                    @using (Html.PB_P().AsSmallMuted().Begin())
                    {
                        @:Learn how to initialize shared server services in your project.
                    }
                    @Html.Button(ActionItemFactory.AspRoute("ServerHelper", "GettingStarted").SetTitle("Getting Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                }
            }
        }
    }
}
